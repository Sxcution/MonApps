SendQuickText(text) {
    DebugLog("SendQuickText triggered -> " . text)
    ClipSaved := ClipboardAll
    Clipboard := text
    ClipWait, 0.5, 1
    if (ErrorLevel) {
        DebugLog("Clipboard not ready, fallback to SendRaw")
        SendRaw, %text%
    } else {
        SendInput, ^v
    }
    Sleep, 100
    Clipboard := ClipSaved
    VarSetCapacity(ClipSaved, 0)
}

DebugLog(message) {
    OutputDebug, 🔍 %message%
}

ChooseSeedPart(options) {
    StringSplit, itemArray, options, |
    itemCount := itemArray0
    if (itemCount < 1) {
        return ""
    }

    Random, itemIndex, 1, %itemCount%
    return itemArray%itemIndex%
}

