; --- Subroutines ---

GuiUpdateSwitches:
    Gui, OnceHuman:Submit, NoHide
    EnableAutoWalk := CbEnableAutoWalk
    EnableAutoFarm := CbEnableAutoFarm
    EnableAutoShoot := CbEnableAutoShoot
    
    ; Save Settings to INI
    IniWrite, %EnableAutoWalk%, MonAHK_Settings.ini, OnceHuman, EnableAutoWalk
    IniWrite, %EnableAutoFarm%, MonAHK_Settings.ini, OnceHuman, EnableAutoFarm
    IniWrite, %EnableAutoShoot%, MonAHK_Settings.ini, OnceHuman, EnableAutoShoot
    
    ; Stop any running actions if features are disabled
    if (!EnableAutoWalk && AutoWalkState) {
        Send, {w up}
        AutoWalkState := 0
    }
    if (!EnableAutoFarm && AutoFarmState) {
        SetTimer, SpamF_Timer, Off
        AutoFarmState := 0
    }
    if (!EnableAutoShoot && AutoShootState) {
        Send, {LButton up}
        AutoShootState := 0
    }
return

ToggleAutoWalk:
    if (AutoWalkState) {
        Send, {w up}
        AutoWalkState := 0
    } else {
        Send, {w down}
        AutoWalkState := 1
    }
return

ToggleAutoFarm:
    if (AutoFarmState) {
        SetTimer, SpamF_Timer, Off
        AutoFarmState := 0
    } else {
        SetTimer, SpamF_Timer, 500
        AutoFarmState := 1
    }
return

ToggleAutoShoot:
    if (AutoShootState) {
        Send, {LButton up}
        AutoShootState := 0
    } else {
        Send, {LButton down}
        AutoShootState := 1
    }
return

SpamF_Timer:
    ; Sử dụng ControlSend để gửi phím vào cửa sổ game ngay cả khi không active
    ControlSend, , f, ahk_exe ONCE_HUMAN.exe
return
