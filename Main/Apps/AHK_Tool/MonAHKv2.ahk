    IniWrite, %EnableAutoFarm%, MonAHK_Settings.ini, OnceHuman, EnableAutoFarm
    IniWrite, %EnableAutoSpace%, MonAHK_Settings.ini, OnceHuman, EnableAutoSpace
    IniWrite, %EnableAutoClick%, MonAHK_Settings.ini, OnceHuman, EnableAutoClick
    
    ; Safety: If disabled, stop any running actions immediately
    if (!EnableAutoWalk && AutoWalkState) {
        Send, {w up}
        AutoWalkState := 0
