; Random words generator (Wrapped in hotkey to prevent auto-exec)
^4::
    ; Danh sách từ (có thể thêm/sửa tùy ý) - Khoảng 60 từ
    words := "hello|hi|you|love|xinh|good|fine|chào|yêu|đẹp|ok|yes|no|thank|cảm ơn|baby|nice|like|bye|xu|rãnh|xênh|đáng|ốn|trăng|trời|sao|gió|mây|ngủ|nghĩ|nằm|ngồi|thức|đi|về|ăn|uống|chơi|học|làm|nói|nghe|nhìn|thấy|biết|hiểu|muốn|cần|thích|ghét|vui|buồn|hạnh phúc|lo lắng|bình yên|tự do|ước mơ|hy vọng"
    
    ; Đếm số từ
    StringSplit, wordArray, words, |
    wordCount := wordArray0
    
    ; Kiểm tra danh sách từ có rỗng không
    if (wordCount = 0) {
        return
    }
    
    ; Random số từ (1-5)
    Random, numWords, 1, 5
    
    ; Giới hạn số từ không vượt quá số từ có sẵn
    if (numWords > wordCount) {
        numWords := wordCount
    }
    
    ; Chọn random từ (tránh trùng lặp)
    selectedIndices := ""
    selectedCount := 0
    
    Loop, 100 {  ; Giới hạn 100 lần thử để tránh vòng lặp vô hạn
        if (selectedCount >= numWords) {
            Break
        }
        
        Random, randomIndex, 1, %wordCount%
        
        ; Kiểm tra xem index đã được chọn chưa
        found := false
        if (selectedIndices != "") {
            StringSplit, indexArray, selectedIndices, |
            Loop, %indexArray0% {
                if (indexArray%A_Index% = randomIndex) {
                    found := true
                    Break
                }
            }
        }
        
        ; Nếu chưa chọn thì thêm vào
        if (!found) {
            if (selectedIndices = "") {
                selectedIndices := randomIndex
            } else {
                selectedIndices := selectedIndices . "|" . randomIndex
            }
            selectedCount++
        }
    }
    
    ; Lấy các từ đã chọn
    StringSplit, indexArray, selectedIndices, |
    selectedWords := ""
    Loop, %indexArray0% {
        wordIndex := indexArray%A_Index%
        selectedWord := wordArray%wordIndex%
        if (selectedWords = "") {
            selectedWords := selectedWord
        } else {
            selectedWords := selectedWords . "|" . selectedWord
        }
    }
    
    ; Xáo trộn thứ tự (shuffle) - Fisher-Yates
    StringSplit, selectedArray, selectedWords, |
    selectedCount := selectedArray0
    
    Loop, %selectedCount% - 1 {
        Random, j, %A_Index%, %selectedCount%
        temp := selectedArray%A_Index%
        selectedArray%A_Index% := selectedArray%j%
        selectedArray%j% := temp
    }
    
    ; Gõ từng từ đã xáo trộn (ngăn cách bởi dấu cách)
    SendMode Input
    Loop, %selectedCount% {
        if (A_Index > 1) {
            Send, {Space}
        }
        SendInput, % selectedArray%A_Index%
    }
return

